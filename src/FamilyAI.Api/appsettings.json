{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=ai_tutor;Username=pruva;Password=change_this_password"
  },
  "Jwt": {
    "Secret": "change_this_very_long_secret_32_chars_minimum"
  },
  "AiFallbackSettings": {
    "PriorityOrder": [ "CommandAi", "Gemini", "ChatGPT", "OpenCode" ],
    "Providers": {
      "Gemini": {
        "ApiKey": "YOUR_GEMINI_API_KEY_HERE",
        "Model": "gemini-2.0-flash",
        "Url": "https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent?key={apiKey}"
      },
      "CommandAi": {
        "ApiKey": "YOUR_COMMAND_AI_API_KEY_HERE",
        "Model": "gemini-2.0-flash",
        "Url": "https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent?key={apiKey}"
      },
      "ChatGPT": {
        "ApiKey": "YOUR_CHATGPT_API_KEY_HERE",
        "Model": "gpt-4o-mini",
        "Url": "https://api.openai.com/v1/chat/completions"
      },
      "OpenCode": {
        "ApiKey": "YOUR_OPEN_CODE_API_KEY_HERE",
        "Model": "meta-llama/llama-3-8b-instruct:free",
        "Url": "https://openrouter.ai/api/v1/chat/completions"
      }
    }
  },
  "LiveKit": {
    "Url": "ws://localhost:7880",
    "ApiKey": "devkey",
    "ApiSecret": "devsecretkeyshouldbe48characterslongforsecurity!"
  },
  "Otp": {
    "Provider": "Mock",
    "ExpiryMinutes": 5
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
